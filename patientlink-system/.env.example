# PatientLink Environment Variables
# Copy this file to .env and fill in the values

# Django Auth Service
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# FastAPI Service
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001

# Frontend
VITE_AUTH_API_URL=/api
VITE_PATIENT_API_URL=/patients

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/patientlink
POSTGRES_PASSWORD=change-this-password

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0
ENABLE_BACKGROUND_TASKS=false
BACKUP_DIR=./backups

# Meta WhatsApp Business API
# Get these from Meta Developer Portal: https://developers.facebook.com/
ENABLE_WHATSAPP=false
META_WHATSAPP_TOKEN=your-whatsapp-access-token
META_PHONE_NUMBER_ID=your-phone-number-id
META_WHATSAPP_BUSINESS_ID=your-business-account-id
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your-meta-app-secret

# Security hardening
ENABLE_CAPTCHA=false
CAPTCHA_PROVIDER=recaptcha
RECAPTCHA_SECRET_KEY=
HCAPTCHA_SECRET_KEY=
ENABLE_ADMIN_2FA=false

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
