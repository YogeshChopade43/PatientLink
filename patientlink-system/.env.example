# PatientLink Environment Variables
# Copy this file to .env and fill in the values

# Django Auth Service
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# FastAPI Service
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001

# Frontend
VITE_AUTH_API_URL=/api
VITE_PATIENT_API_URL=/patients

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/patientlink

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Meta WhatsApp Business API
# Get these from Meta Developer Portal: https://developers.facebook.com/
META_WHATSAPP_TOKEN=your-whatsapp-access-token
META_PHONE_NUMBER_ID=your-phone-number-id
META_WHATSAPP_BUSINESS_ID=your-business-account-id
